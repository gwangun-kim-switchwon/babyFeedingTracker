rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwnerOrLinked(userId) {
      let linked = get(/databases/$(database)/documents/users/$(userId)/profile/linked);
      return request.auth.uid == userId || linked.data.linkedTo == request.auth.uid;
    }

    match /users/{userId}/profile/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || request.resource.data.linkedTo == request.auth.uid);
    }

    match /users/{userId}/feeding_records/{recordId} {
      allow read, write: if request.auth != null && isOwnerOrLinked(userId);
    }

    match /users/{userId}/cleaning_records/{recordId} {
      allow read, write: if request.auth != null && isOwnerOrLinked(userId);
    }

    match /users/{userId}/diaper_records/{recordId} {
      allow read, write: if request.auth != null && isOwnerOrLinked(userId);
    }

    match /users/{userId}/sleep_records/{recordId} {
      allow read, write: if request.auth != null && isOwnerOrLinked(userId);
    }

    match /invite_codes/{code} {
      allow read, write: if request.auth != null;
    }

  }
}
