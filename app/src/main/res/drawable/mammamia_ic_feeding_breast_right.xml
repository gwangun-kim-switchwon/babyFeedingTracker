<?xml version="1.0" encoding="utf-8"?>
<!--
    Mammamia custom icon: 모유 수유 (오른쪽)
    24x24 grid, 2dp stroke, round cap/join. R9 §2.3 명세 기준.
    breast_left의 x축 미러링 (x' = 24 - x).
    - 아기 머리 (중앙 큰 원, stroke): cx=12, cy=14, r=5
    - 가슴 (우측 작은 원, fill): cx=18, cy=11, r=3
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- 가슴 (우측 작은 원, fill) -->
    <path
        android:fillColor="#000000"
        android:pathData="M15,11 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0 Z" />
    <!-- 아기 머리 (중앙 큰 원, stroke only) -->
    <path
        android:strokeWidth="2"
        android:strokeColor="#000000"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M7,14 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0 Z" />
</vector>
