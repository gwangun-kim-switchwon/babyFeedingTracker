<?xml version="1.0" encoding="utf-8"?>
<!--
    Mammamia custom icon: 분유 젖병
    24x24 grid, 2dp stroke, round cap/join.
    - 젖꼭지: 상단 작은 사각 라운드 (x=10,y=2,w=4,h=3)
    - 몸통: 세로 직사각 라운드 (x=7,y=6,w=10,h=16, rx=3)
    - 눈금선 2개 (몸통 내부 수평선)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- 젖꼭지 (상단 작은 사각 라운드) -->
    <path
        android:strokeWidth="2"
        android:strokeColor="#000000"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M10,2 L14,2 Q15,2 15,3 L15,5 L9,5 L9,3 Q9,2 10,2 Z" />
    <!-- 몸통 (세로 직사각 라운드) -->
    <path
        android:strokeWidth="2"
        android:strokeColor="#000000"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M8,8 Q8,6 10,6 L14,6 Q16,6 16,8 L16,20 Q16,22 14,22 L10,22 Q8,22 8,20 Z" />
    <!-- 눈금선 1 (위) -->
    <path
        android:strokeWidth="1.5"
        android:strokeColor="#000000"
        android:strokeLineCap="round"
        android:pathData="M10,12 L14,12" />
    <!-- 눈금선 2 (아래) -->
    <path
        android:strokeWidth="1.5"
        android:strokeColor="#000000"
        android:strokeLineCap="round"
        android:pathData="M10,16 L14,16" />
</vector>
