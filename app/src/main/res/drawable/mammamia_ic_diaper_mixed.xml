<?xml version="1.0" encoding="utf-8"?>
<!--
    Mammamia custom icon: 기저귀 (혼합: 소변 + 대변)
    24x24 grid, 2dp stroke, round cap/join.
    - 사다리꼴 기저귀 실루엣 (pee/poo와 동일)
    - 중앙 원 1개 (fill) — 소변 방울 메타포 공유
    - 상단 작은 점 1개 — 혼합 표시
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- 기저귀 사다리꼴 실루엣 -->
    <path
        android:strokeWidth="2"
        android:strokeColor="#000000"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M4,6 L20,6 L17,18 Q16,20 14,20 L10,20 Q8,20 7,18 Z" />
    <!-- 중앙 원 (fill) -->
    <path
        android:fillColor="#000000"
        android:pathData="M12,12 a1.5,1.5 0 1,0 0.01,0 Z" />
    <!-- 상단 작은 점 (혼합 표시) -->
    <path
        android:fillColor="#000000"
        android:pathData="M12,9 a0.7,0.7 0 1,0 0.01,0 Z" />
</vector>
