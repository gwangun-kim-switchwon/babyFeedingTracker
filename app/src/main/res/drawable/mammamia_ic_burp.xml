<?xml version="1.0" encoding="utf-8"?>
<!--
    Mammamia custom icon: 트림
    24x24 grid, 2dp stroke, round cap/join.
    - 아기 옆얼굴 (좌측, 반원 형태)
    - 입 앞에 공기방울 3개 (크기 gradient: 작은 -> 중간 -> 큰)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- 아기 옆얼굴 (좌측 반원: 좌측 열림, 우측으로 볼록) -->
    <path
        android:strokeWidth="2"
        android:strokeColor="#000000"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M7,5 Q13,5 13,12 Q13,19 7,19" />
    <!-- 공기방울 1 (가장 작음, 입 근처) -->
    <path
        android:fillColor="#000000"
        android:pathData="M15,12 a0.8,0.8 0 1,0 0.01,0 Z" />
    <!-- 공기방울 2 (중간) -->
    <path
        android:strokeWidth="1.5"
        android:strokeColor="#000000"
        android:fillColor="#00000000"
        android:pathData="M18,12 a1.3,1.3 0 1,0 0.01,0 Z" />
    <!-- 공기방울 3 (가장 큼) — viewBox 24 내부 수렴 -->
    <path
        android:strokeWidth="1.5"
        android:strokeColor="#000000"
        android:fillColor="#00000000"
        android:pathData="M21,10 a1.5,1.5 0 1,0 0.01,0 Z" />
</vector>
